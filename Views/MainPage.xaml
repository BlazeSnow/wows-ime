<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="wows_ime.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:wows_ime.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="战舰世界输入法配置工具" />
                <TextBlock Text="扫描本机输入法，勾选并指定类型后写入游戏目录的 ime_config.xml。" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="6">
                <TextBlock Text="游戏根目录" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        x:Name="GameRootPathBox"
                        HorizontalAlignment="Stretch"
                        IsEditable="True"
                        SelectionChanged="GameRootPathBox_SelectionChanged"
                        LostFocus="GameRootPathBox_LostFocus"
                        VerticalAlignment="Center">
                        <x:String>C:\Program Files (x86)\Steam\steamapps\common\World of Warships</x:String>
                        <x:String>C:\Games\Korabli</x:String>
                        <x:String>C:\Games\World_of_Warships_CN360</x:String>
                    </ComboBox>
                    <Button Grid.Column="1" Click="OpenFolderButton_Click" Content="打开目录" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Click="PickFolderButton_Click" Content="选择目录" VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <Border Grid.Row="2" Padding="12" BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="检测到的输入法" />
                        <Button Grid.Column="1" Click="AddCustomImeButton_Click" Content="自定义输入法名称" />
                        <Button Grid.Column="2" Click="RefreshImeButton_Click" Content="重新扫描" />
                    </Grid>
                    <ListView Grid.Row="1" x:Name="ImeListView" VerticalAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{x:Bind InputMethods, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:InputMethodItem">
                                <Grid Padding="0,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        MinWidth="0"
                                        MinHeight="0"
                                        Padding="0"
                                        Margin="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind DisplayName}" />
                                    <ComboBox Grid.Column="2" SelectedIndex="{x:Bind CategoryIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="中文简体" />
                                        <ComboBoxItem Content="中文繁体" />
                                        <ComboBoxItem Content="日文" />
                                    </ComboBox>
                                    <Button
                                        Grid.Column="3"
                                        Click="DeleteCustomImeButton_Click"
                                        Content="删除"
                                        HorizontalAlignment="Stretch"
                                        Tag="{x:Bind}"
                                        Visibility="{x:Bind DeleteButtonVisibility, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Click="WriteConfigButton_Click" Content="写入配置" Style="{StaticResource PrimaryAction}" />
            </StackPanel>

            <InfoBar Grid.Row="4" x:Name="StatusInfoBar" IsOpen="False" IsClosable="False" Margin="0,4,0,0" />
        </Grid>
    </Page.Content>
</Page>
