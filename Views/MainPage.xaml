<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="wows_ime.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:wows_ime.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Padding="24" RowSpacing="12" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock x:Uid="MainTitleText" FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Uid="MainSubtitleText" TextWrapping="WrapWholeWords" />
            </StackPanel>

            <toolkit:SettingsExpander Grid.Row="1" IsExpanded="True">
                <toolkit:SettingsExpander.Header>
                    <TextBlock x:Uid="GameRootLabel" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
                </toolkit:SettingsExpander.Header>
                <toolkit:SettingsExpander.Items>
                    <toolkit:SettingsCard ContentAlignment="Vertical" HorizontalContentAlignment="Stretch">
                        <Grid Margin="0,8,0,0" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="GamePathSectionHint" VerticalAlignment="Center" />
                                <Button x:Uid="AddCustomGamePathButton" Grid.Column="1" Click="AddCustomGamePathButton_Click" VerticalAlignment="Center" />
                                <Button x:Uid="OpenFolderButton" Grid.Column="2" Click="OpenFolderButton_Click" VerticalAlignment="Center" />
                            </Grid>

                            <ListView
                                Grid.Row="1"
                                x:Name="GamePathListView"
                                ItemsSource="{x:Bind GamePathOptions, Mode=OneWay}"
                                SelectionMode="None"
                                IsItemClickEnabled="False"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:GamePathOption">
                                        <Grid Padding="0,4" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <RadioButton
                                                GroupName="GamePathGroup"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                Checked="GamePathRadioButton_Checked"
                                                Tag="{x:Bind}" />
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind DisplayName}" />
                                                <TextBlock Text="{x:Bind Path}" Opacity="0.72" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                            <Button
                                                x:Uid="DeleteCustomGamePathButtonTemplate"
                                                Grid.Column="2"
                                                Click="DeleteCustomGamePathButton_Click"
                                                Tag="{x:Bind}"
                                                Visibility="{x:Bind DeleteButtonVisibility, Mode=OneWay}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </toolkit:SettingsCard>
                </toolkit:SettingsExpander.Items>
            </toolkit:SettingsExpander>

            <toolkit:SettingsExpander Grid.Row="2" IsExpanded="True" VerticalAlignment="Stretch">
                <toolkit:SettingsExpander.Header>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="ImeSectionTitle" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
                        <Button x:Uid="AddCustomImeButton" Grid.Column="1" Click="AddCustomImeButton_Click" />
                        <Button x:Uid="RefreshImeButton" Grid.Column="2" Click="RefreshImeButton_Click" />
                    </Grid>
                </toolkit:SettingsExpander.Header>

                <toolkit:SettingsExpander.Items>
                    <toolkit:SettingsCard ContentAlignment="Vertical" HorizontalContentAlignment="Stretch">
                        <Grid Margin="0,8,0,0" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="ImeTableHeaderName" Grid.Column="1" FontWeight="SemiBold" />
                            <TextBlock x:Uid="ImeTableHeaderCategory" Grid.Column="2" FontWeight="SemiBold" />
                            <TextBlock x:Uid="ImeTableHeaderAction" Grid.Column="3" FontWeight="SemiBold" />

                            <ListView
                                Grid.Row="1"
                                Grid.ColumnSpan="4"
                                x:Name="ImeListView"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                ScrollViewer.VerticalScrollMode="Enabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ItemsSource="{x:Bind InputMethods, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:InputMethodItem">
                                        <Grid Padding="0,4" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox
                                                MinWidth="0"
                                                MinHeight="0"
                                                Padding="0"
                                                Margin="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind DisplayName}" />
                                            <ComboBox Grid.Column="2" SelectedIndex="{x:Bind CategoryIndex, Mode=TwoWay}">
                                                <ComboBoxItem x:Uid="ImeCategorySimplifiedItem" />
                                                <ComboBoxItem x:Uid="ImeCategoryTraditionalItem" />
                                                <ComboBoxItem x:Uid="ImeCategoryJapaneseItem" />
                                            </ComboBox>
                                            <Button
                                                x:Uid="DeleteCustomImeButtonTemplate"
                                                Grid.Column="3"
                                                Click="DeleteCustomImeButton_Click"
                                                HorizontalAlignment="Stretch"
                                                Tag="{x:Bind}"
                                                Visibility="{x:Bind DeleteButtonVisibility, Mode=OneWay}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </toolkit:SettingsCard>
                </toolkit:SettingsExpander.Items>
            </toolkit:SettingsExpander>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                <Button x:Uid="WriteConfigButton" Click="WriteConfigButton_Click" Style="{StaticResource PrimaryAction}" />
            </StackPanel>

            <InfoBar Grid.Row="4" x:Name="StatusInfoBar" IsOpen="False" IsClosable="False" Margin="0,4,0,0" />
        </Grid>
    </Page.Content>
</Page>
